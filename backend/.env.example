# ==========================================
# BestDel Backend Environment Configuration
# ==========================================

# --- Server Configuration ---
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:5173
LOG_LEVEL=debug
STREAM_TIMEOUT_MS=600000

# --- Supabase Database & Cache ---
# Required for persistent cache and history.
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_JWT_SECRET=your_jwt_secret

# --- Local Database Fallback ---
DATABASE_URL=sqlite:./bestdel.db

# --- Redis Configuration (Optional) ---
# Used for rate limiting and transient caching.
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token
# REDIS_URL=redis://localhost:6379

# --- Retrieval Cache Settings ---
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_DEFAULT_TTL_SECONDS=604800
RETRIEVAL_CACHE_NEGATIVE_TTL_SECONDS=3600
RETRIEVAL_CACHE_FRESH_TTL_SECONDS=43200
RETRIEVAL_CACHE_MAX_ENTRY_BYTES=5242880
RETRIEVAL_CACHE_SCHEMA_VERSION=1
RETRIEVAL_CACHE_DEBUG=true

# --- Concurrency Limits ---
MAX_DEEP_RESEARCH_CONCURRENCY=3
MAX_WEB_SEARCH_CONCURRENCY=8

# ==========================================
# AI Model Providers (Multi-Key Fallback)
# ==========================================

OPENAI_API_KEY_1=your_openai_api_key_1
OPENAI_API_KEY_2=your_openai_api_key_2
OPENAI_API_KEY_3=your_openai_api_key_3

ANTHROPIC_API_KEY_1=your_anthropic_api_key_1
